{
  "name": "@neolution-ch/javascript-utils",
  "version": "2.4.0",
  "description": "This is a collection of utilities that we have created to help with our development process.",
  "homepage": "https://neolution-ch.github.io/javascript-utils",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neolution-ch/javascript-utils"
  },
  "license": "MIT",
  "author": "Neolution",
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.modern.js",
      "require": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "module": "dist/index.modern.js",
  "source": "src/index.ts",
  "jsnext:main": "dist/index.modern.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c --configPlugin rollup-plugin-typescript2",
    "lint": "eslint --cache",
    "prepack": "yarn build",
    "prepare-pr": "yarn prettier . --write && yarn lint && yarn build && yarn test",
    "prettier-check": "prettier --check .",
    "prettier-write": "prettier --write .",
    "start": "rollup -c -w",
    "pretest": "tsc -p tsconfig.json --showConfig > tsconfig.jest.json",
    "test": "cross-env TZ=Europe/Zurich TS_NODE_PROJECT='tsconfig.jest.json' yarn jest",
    "start-all": "concurrently \"yarn start\" \"yarn start-yalc\"",
    "start-yalc": "yarn nodemon --watch dist -x \"yarn yalc push\""
  },
  "dependencies": {
    "date-fns": "^2.30.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@neolution-ch/eslint-config-neolution": "^2.5.0",
    "@release-it/keep-a-changelog": "^7.1.0",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@swc/core": "^1.15.41",
    "@swc/jest": "^0.2.39",
    "@tsconfig/recommended": "^1.0.13",
    "@tsconfig/strictest": "^2.0.8",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.43",
    "@types/rollup-plugin-peer-deps-external": "^2.2.6",
    "@types/uuid": "^9.0.7",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "jest": "^30.4.2",
    "jest-localstorage-mock": "^2.4.26",
    "jiti": "^2.7.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4",
    "release-it": "^20.2.0",
    "rollup": "^4.62.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-typescript2": "^0.37.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "yalc": "^1.0.0-pre.53"
  },
  "resolutions": {
    "eslint-plugin-cypress": "5.2.0"
  },
  "peerDependencies": {},
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}

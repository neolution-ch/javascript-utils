{
  "extends": ["@tsconfig/recommended/tsconfig.json", "@tsconfig/strictest/tsconfig.json"],
  "compilerOptions": {
    "outDir": "dist",
    "module": "ESNext",
    "target": "ESNext",
    "lib": ["dom", "esnext"],
    "types": ["node", "jest"],
    "moduleResolution": "bundler",
    "sourceMap": true,
    "declaration": true
  },
  "include": ["src", "test"],
  "exclude": ["node_modules", "dist", "coverage"],
  "files": ["rollup.config.ts", "jest.config.ts", "eslint.config.ts"]
}
